#############################################
# Legacy Sentinel Configuration
#############################################

# ==========================
# Discord Application
# ==========================
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# ==========================
# Owner IDs
# ==========================
OWNER_ID=your_discord_user_id_here

# ==========================
# PostgreSQL Database
# ==========================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=legacy_sentinel
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ==========================
# Dashboard
# ==========================
DASHBOARD_PORT=3000
SESSION_SECRET=LegacyCloudSentinelSecretKeyToken987654321!
DOMAIN=http://your_server_ip_here:3000

# ==========================
# Backup Settings
# ==========================
BACKUP_INTERVAL=12h
MAX_BACKUPS=30

# ==========================
# Security
# ==========================
AUTO_BAN=true
AUTO_RECOVERY=true
NUKE_THRESHOLD=5
WHITELIST_BYPASS=true

# ==========================
# Logs
# ==========================
LOG_LEVEL=info

#############################################
# Legacy Sentinel
#############################################
