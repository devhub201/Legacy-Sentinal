#############################################
# Legacy Sentinel Configuration
#############################################

# ==========================
# Discord Application
# ==========================
TOKEN=
CLIENT_ID=
CLIENT_SECRET=

# ==========================
# Owner IDs
# ==========================
OWNER_ID=
DIABLO_ID=

# ==========================
# PostgreSQL Database
# ==========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=legacy_sentinel
DB_USER=postgres
DB_PASSWORD=

# ==========================
# Dashboard
# ==========================
DASHBOARD_PORT=3000
SESSION_SECRET=
DOMAIN=http://localhost:3000

# ==========================
# Backup Settings
# ==========================
BACKUP_INTERVAL=12h
MAX_BACKUPS=30

# ==========================
# Security
# ==========================
AUTO_BAN=true
AUTO_RECOVERY=true
NUKE_THRESHOLD=5
WHITELIST_BYPASS=true

# ==========================
# Logs
# ==========================
LOG_LEVEL=info

#############################################
# Legacy Sentinel
#############################################
